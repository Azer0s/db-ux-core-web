{
  "name": "@db-ux/react-native-core-components",
  "version": "4.5.4",
  "description": "React Native components for @db-ux/core-components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "assets/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm-run-all tsc --parallel mv:*",
    "mv:dist": "cpr dist ../../build-outputs/react-native/dist --overwrite",
    "mv:changelog": "cpr CHANGELOG.md ../../build-outputs/react-native/CHANGELOG.md --overwrite",
    "mv:package.json": "cpr package.json ../../build-outputs/react-native/package.json --overwrite",
    "mv:readme": "cpr README.md ../../build-outputs/react-native/README.md --overwrite",
    "tsc": "tsc --project . --sourceMap false"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-svg": ">=13.0.0"
  },
  "dependencies": {
    "@db-ux/core-components": "4.5.4",
    "@expo/vector-icons": "^14.0.0",
    "expo-font": ">=12.0.0",
    "expo-linking": "^6.0.0"
  },
  "devDependencies": {
    "@db-ux/core-foundations": "4.5.4",
    "@types/react": "19.2.14",
    "@types/react-native": "^0.72.0",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "^15.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "sideEffects": false
}
